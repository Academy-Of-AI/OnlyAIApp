# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Vibe Launchpad

# ── Supabase (this portal's own Supabase project) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Create at: github.com/settings/applications/new
# Callback URL: {APP_URL}/api/github/callback
# Scopes needed: repo, user:email
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Vercel API ───────────────────────────────────────────────────────────────
# Users provide their own Vercel token via the UI (stored encrypted in DB)
# This is YOUR portal's Vercel token for any admin-level ops
VERCEL_ADMIN_TOKEN=

# ── GitHub template source ───────────────────────────────────────────────────
# The template repo users' projects will be created from
GITHUB_TEMPLATE_OWNER=xp-luffy
GITHUB_TEMPLATE_REPO=vibe-stack-supabase

# ── Stripe (portal's own Stripe account) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── PostHog ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Encryption (for storing OAuth tokens) ────────────────────────────────────
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=
