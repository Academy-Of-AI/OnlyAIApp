# Copy to .env.local and fill in. In production these live in Vercel env vars.
# Fastest way to get a local copy of what's in Vercel:  vercel env pull .env.local

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (this portal's own project) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # service role — server only, never exposed

# ── Encryption (for storing users' OAuth tokens) ─────────────────────────────
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Create: github.com/settings/applications/new  · Callback: {APP_URL}/api/github/callback
# Scopes: repo, user:email
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Vercel OAuth (users connect their own Vercel) ────────────────────────────
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=

# ── Template the users' projects are created from ────────────────────────────
GITHUB_TEMPLATE_OWNER=xp-luffy
GITHUB_TEMPLATE_REPO=vibe-stack-supabase

# ── Anthropic (control-plane AI: digest/plan/drift/retro — Pro features) ─────
# Get a key at console.anthropic.com
ANTHROPIC_API_KEY=

# ── Stripe (Pro subscription) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── Auto-capture webhook + weekly cron (you invent these — random strings) ───
# Generate each: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=
CRON_SECRET=

# ── Notification emails (optional) ───────────────────────────────────────────
RESEND_API_KEY=                     # from resend.com
NOTIFY_EMAIL=                       # where alerts go (your email)

# ── Analytics (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Build mode (leave OFF — users build with their own Claude Code) ──────────
# Set to "true" only to re-enable the owner-funded in-app generator.
OWNER_FUNDED_BUILDS=false
